# ── Core contracts ────────────────────────────────────────────────────────────
# USDC bridged via CCTP (Noble → Initia), standard ERC-20 on EVM layer
USDC_ADDRESS=0x...

# Agent hot wallet public address (signs rebalance transactions)
AGENT_SIGNER_ADDRESS=0x...

# ── DEX / Strategy ────────────────────────────────────────────────────────────
# Uniswap V2 compatible router deployed on the NEURALIS EVM chain
DEX_ROUTER_ADDRESS=0x...

# USDC/tokenB LP pair contract address (must exist before deploying)
DEX_PAIR_ADDRESS=0x...

# Second token in the USDC/tokenB LP pair (e.g. INIT or NEURAL)
DEX_TOKEN_B_ADDRESS=0x...

# Initial APY estimate in basis points (e.g. 500 = 5.00%)
DEX_INITIAL_APY=500

# Initial risk score 0-100 (lower = safer; e.g. 25 = low risk)
DEX_INITIAL_RISK=25

# ── Verification ──────────────────────────────────────────────────────────────
INITIASCAN_URL=https://scan.initia.tech/api
INITIASCAN_API_KEY=
