# ── Deployer ──────────────────────────────────────────────────────────────────
PRIVATE_KEY=0x...
DEPLOYER_ADDRESS=0x...

# ── Target chain ──────────────────────────────────────────────────────────────
# EVM Minitia options (type: minievm):
#
#   cabal   — chain ID 2630341494499703
#             RPC: https://jsonrpc-cabal-1.anvil.asia-southeast.initia.xyz
