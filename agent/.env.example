# ── NEURALIS EVM Chain ────────────────────────────────────────────────────────
# neuralis-1 testnet EVM-compatible RPC
RPC_URL=https://jsonrpc-evm-1.anvil.asia-southeast.initia.xyz

# ── EVM Contract addresses (fill from deployments.json after forge script) ────
VAULT_MANAGER_ADDRESS=0x...
STRATEGY_REGISTRY_ADDRESS=0x...
KEEPER_EXECUTOR_ADDRESS=0x...

# ── EVM Agent wallet ──────────────────────────────────────────────────────────
# This key's public address must match AGENT_SIGNER_ADDRESS in KeeperExecutor
KEEPER_PRIVATE_KEY=0x...

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/neuralis

# ── Tuning ────────────────────────────────────────────────────────────────────
CRON_INTERVAL_MINUTES=30
# Skip rebalance if no strategy delta exceeds this (basis points)
MIN_REBALANCE_THRESHOLD_BPS=50

# ── MoveVM (LaborBadge + ProgrammableIntents) ─────────────────────────────────
# Cosmos REST endpoint of the NEURALIS Minitia
MOVE_REST_URL=http://localhost:1317

# Chain ID of the Minitia (from weave init / minitiad config)
MOVE_CHAIN_ID=neuralis-1

# Hex address of the Move module deployer (= output of `initiad keys parse <INIT_ADDR>`)
# This is also the address under which the modules are published.
MOVE_MODULE_ADDRESS=0x...

# 24-word mnemonic of the keeper wallet on the Cosmos/Move side.
# The Ed25519 public key derived from this mnemonic must be passed to
# `programmable_intents initialize` as keeper_pubkey.
KEEPER_MNEMONIC="word1 word2 word3 ... word24"

# Bech32 (init1...) address of the keeper on the Cosmos side.
# Used as the badge recipient and intent owner.
KEEPER_INITIA_ADDRESS=init1...
